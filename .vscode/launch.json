{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Vertex DTL: direct",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--bin",
                    "vertex_dtl"
                ],
                "filter": {
                    "name": "vertex_dtl",
                    "kind": "bin"
                }
            },
            "args": [
                "direct"
            ],
            "cwd": "${workspaceFolder}"
        },
